# ============================================================
# Variables de entorno — Proyecto TeleSecure (unificado)
# Copiar a .env y ROTAR todas las contraseñas (ISO 27001 A.5.17)
#
# IMPORTANTE:
#  1) Si cambias las contraseñas aquí, cámbialas TAMBIÉN en
#     db/init.sql ANTES del primer arranque (el script solo corre
#     una vez, cuando el volumen db_data está vacío).
#  2) WEBHOOK_TOKEN debe coincidir con el valor que pongas en
#     midpoint/midpoint-config.xml (campo CAMBIAR_TOKEN_WEBHOOK).
# ============================================================

# --- MariaDB ---
DB_ROOT_PASSWORD=RootCambiar123!

# --- Usuario de midPoint y del webhook (comparten mp_user) ---
MIDPOINT_DB_USER=mp_user
MIDPOINT_DB_PASSWORD=MidpointCambiar123!

# --- Usuario de FreePBX ---
FREEPBX_DB_USER=fpbx_user
FREEPBX_DB_PASSWORD=FreepbxCambiar123!

# --- Token de autenticación del webhook (X-Auth-Token) ---
# Generar uno robusto, ej.:  openssl rand -hex 24
WEBHOOK_TOKEN=CAMBIAR_TOKEN_WEBHOOK

# Credenciales API GraphQL de FreePBX (crear app Machine-to-Machine en Admin->API)
FREEPBX_CLIENT_ID=
FREEPBX_CLIENT_SECRET=
